# API Configuration
# Your API key for external service authentication
API_KEY=your_api_key_here
# Your API secret for external service authentication
API_SECRET=your_api_secret_here
# API endpoint URL (optional, defaults to https://api.example.com)
API_ENDPOINT=https://api.example.com

# Database Configuration
# Database host address
DB_HOST=localhost
# Database port number
DB_PORT=5432
# Database name
DB_NAME=your_database_name
# Database username
DB_USER=your_database_user
# Database password
DB_PASSWORD=your_database_password

# AWS Configuration
# AWS access key ID for AWS services
AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS secret access key for AWS services
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS region (optional, defaults to us-east-1)
AWS_REGION=us-east-1
# S3 bucket name for file storage
AWS_S3_BUCKET=your_s3_bucket_name

# GitHub Configuration
# GitHub personal access token for API access
GITHUB_TOKEN=your_github_token
# GitHub webhook secret for webhook verification
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# JWT Configuration
# Secret key for JWT token signing
JWT_SECRET_KEY=your_jwt_secret_key
# JWT algorithm (optional, defaults to HS256)
JWT_ALGORITHM=HS256
# JWT token expiration in hours (optional, defaults to 24)
JWT_EXPIRATION_HOURS=24

# Payment Gateway Configuration
# Stripe API key for payment processing
STRIPE_API_KEY=your_stripe_api_key
# Stripe webhook secret for webhook verification
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
# PayPal client ID for payment processing
PAYPAL_CLIENT_ID=your_paypal_client_id
# PayPal client secret for payment processing
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Email Configuration
# SMTP server host for sending emails
SMTP_HOST=smtp.example.com
# SMTP server port (optional, defaults to 587)
SMTP_PORT=587
# SMTP username for authentication
SMTP_USER=your_smtp_username
# SMTP password for authentication
SMTP_PASSWORD=your_smtp_password
# Use TLS for SMTP connection (optional, defaults to true)
SMTP_USE_TLS=true

# Redis Configuration
# Redis server host
REDIS_HOST=localhost
# Redis server port (optional, defaults to 6379)
REDIS_PORT=6379
# Redis password for authentication
REDIS_PASSWORD=your_redis_password
# Redis database number (optional, defaults to 0)
REDIS_DB=0

# Application Configuration
# Application secret key for session management
APP_SECRET_KEY=your_app_secret_key
# Enable debug mode (optional, defaults to false)
APP_DEBUG=false
# Application environment (optional, defaults to production)
APP_ENV=production